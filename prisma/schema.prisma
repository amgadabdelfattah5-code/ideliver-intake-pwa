// OPS-INTAKE-01 slice schema from plan.md.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL configured in prisma.config.ts.
}

// WP is system of record for merchants; this is a local cache.
model Merchant {
  id         String    @id @default(cuid())
  wpUserId   Int       @unique
  merchantId String
  name       String
  phone      String?
  cachedAt   DateTime  @default(now())
  sessions   Session[]
}

model Session {
  id          String        @id @default(cuid())
  merchant    Merchant      @relation(fields: [merchantId], references: [id])
  merchantId  String
  createdBy   String
  status      SessionStatus
  photoCount  Int           @default(0)
  createdAt   DateTime      @default(now())
  sentAt      DateTime?
  completedAt DateTime?
  orders      Order[]

  @@index([status, createdAt])
}

model Order {
  id              String       @id @default(cuid())
  session         Session      @relation(fields: [sessionId], references: [id])
  sessionId       String
  sequence        Int
  photoUrl        String
  status          OrderStatus
  aiFields        Json?
  correctedFields Json?
  confidence      Float?
  shipmentId      String?
  reviewedBy      String?
  submittedAt     DateTime?
  claimedBy       String?
  claimedAt       DateTime?
  extraction      Extraction?
  corrections     Correction[]

  @@unique([sessionId, sequence])
  @@index([sessionId, status])
}

model Extraction {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   String   @unique
  provider  String
  model     String
  rawRef    String?
  createdAt DateTime @default(now())
}

model Correction {
  id             String   @id @default(cuid())
  order          Order    @relation(fields: [orderId], references: [id])
  orderId        String
  field          String
  aiValue        String
  correctedValue String
  correctedBy    String
  correctedAt    DateTime @default(now())
}

model ActionLog {
  id       BigInt   @id @default(autoincrement())
  actor    String
  action   String
  entity   String
  entityId String
  at       DateTime @default(now())
  meta     Json?

  @@index([entity, entityId])
}

enum SessionStatus {
  created
  awaiting_extraction
  ready_for_review
  completed
}

enum OrderStatus {
  captured
  extracted
  re_extracted
  submitted
  awaiting_merchant
}
